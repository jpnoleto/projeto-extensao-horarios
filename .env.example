# Configuração de ambiente — copie para .env e preencha com seus valores
# .env NÃO deve ser commitado (já está no .gitignore)

# === Obrigatórias em produção ===

# URL completa de conexão MySQL
# Formato: mysql://usuario:senha@host:porta/banco
DATABASE_URL=mysql://usuario:senha@host:3306/banco_de_dados

# Chave secreta usada pelo Flask para assinar cookies de sessão.
# OBRIGATÓRIA em produção. Gere com:  openssl rand -hex 32
# Se não definida E FLASK_DEBUG=1, usa um fallback inseguro só para dev local.
SECRET_KEY=substitua-por-uma-chave-aleatoria-de-32-bytes


# === Opcionais ===

# Modo debug do Flask. Default: false (produção)
# Em dev local, use FLASK_DEBUG=1 para habilitar tracebacks e templates auto-reload.
FLASK_DEBUG=0

# Cria usuários padrão (diretor@escola.com / diretor123 e secretaria@escola.com / secretaria123)
# ao rodar criar_banco.py. Default: false.
# NUNCA habilite em produção — qualquer um conhece essas senhas.
DB_SEED_DEFAULT_USERS=false

# Porta HTTP (preenchida automaticamente por Railway/Heroku/Render).
# Em local, default 5000.
PORT=5000
